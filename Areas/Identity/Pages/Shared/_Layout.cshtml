<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebChat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <style>
        .auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f5f3ff 0%, #e0e7ff 100%);
            padding: 20px;
        }
        .auth-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.08);
            transition: all 0.3s ease;
        }
        .auth-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 24px;
            color: var(--primary);
        }
        .auth-logo span.logo-text {
            font-size: 1.5rem;
            font-weight: 900;
            letter-spacing: -0.5px;
        }
        .auth-logo span.material-symbols-outlined {
            font-size: 2.2rem;
            font-variation-settings: 'FILL' 1;
        }
        /* Customize Identity internal styles */
        h1, h2, h3 {
            font-size: 1.5rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 8px;
            color: var(--on-surface);
        }
        h2 {
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--on-surface-variant);
            margin-bottom: 24px;
            text-align: center;
        }
        hr {
            display: none; /* Hide default hr */
        }
        /* Form inputs customization */
        .form-floating {
            margin-bottom: 16px;
        }
        .form-floating > .form-control {
            border-radius: 12px;
            border: 1px solid var(--border-color);
            background-color: rgba(255, 255, 255, 0.6);
        }
        .form-floating > .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--primary-container);
            background-color: #ffffff;
        }
        .checkbox label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
            color: var(--on-surface-variant);
            cursor: pointer;
        }
        .form-check-input {
            border-radius: 4px;
            border-color: var(--border-color);
        }
        .form-check-input:checked {
            background-color: var(--primary);
            border-color: var(--primary);
        }
        /* Buttons */
        .btn-primary {
            background: var(--user-msg-gradient) !important;
            border: none !important;
            border-radius: 12px !important;
            padding: 12px 24px !important;
            font-weight: 700 !important;
            font-size: 1rem !important;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25) !important;
            transition: all 0.2s ease !important;
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(99, 102, 241, 0.35) !important;
        }
        .btn-primary:active {
            transform: translateY(1px);
        }
        /* Secondary links */
        .auth-links {
            margin-top: 24px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            text-align: center;
            font-size: 0.875rem;
        }
        .auth-links a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.15s ease;
        }
        .auth-links a:hover {
            color: var(--primary-hover);
            text-decoration: underline;
        }
        /* Hide secondary external login panel if empty */
        .col-lg-4.col-lg-offset-2, .col-md-6.col-md-offset-2 {
            display: none !important;
        }
        .row > * {
            width: 100% !important;
            max-width: 100% !important;
            flex: 0 0 100% !important;
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <span class="material-symbols-outlined">bubble_chart</span>
                <span class="logo-text">WebChat Pro</span>
            </div>
            
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Group the bottom links inside a nice auth-links container
            const form = document.querySelector('form');
            if (form) {
                const linksContainer = document.createElement('div');
                linksContainer.className = 'auth-links';
                
                // Find all anchor tags that are not the submit button or validation helpers
                const links = Array.from(form.querySelectorAll('a'));
                links.forEach(link => {
                    // Check if it's external service link, keep it if so
                    if (!link.closest('.col-lg-4')) {
                        linksContainer.appendChild(link);
                    }
                });
                
                // Remove empty paragraph tags from form
                const paragraphs = Array.from(form.querySelectorAll('p'));
                paragraphs.forEach(p => {
                    if (p.querySelector('a')) {
                        p.remove();
                    }
                });
                
                form.appendChild(linksContainer);
            }
        });
    </script>
</body>
</html>
