<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebChat</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebChat.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
@{
    var path = Context.Request.Path.Value ?? string.Empty;
    var bodyClass = path.StartsWith("/Chat", StringComparison.OrdinalIgnoreCase)
        ? "chat-page"
        : path.StartsWith("/Identity/Account/Manage", StringComparison.OrdinalIgnoreCase)
            ? "manage-page"
            : path.StartsWith("/Identity/Account", StringComparison.OrdinalIgnoreCase)
                ? "auth-page"
                : "app-page";
}
<body class="@bodyClass">
    <div class="container-fluid vh-100 p-0 overflow-hidden">
        <main role="main" class="h-100">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
