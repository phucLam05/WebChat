@page "{chatId:int?}"
@model WebChat.Pages.ChatModel
@{
    ViewData["Title"] = "Chat - WebChat";
}

@section Styles {
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
}

@{
    string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }

    string GetChatName(WebChat.Models.Chat chat, string currentUserId)
    {
        if (chat.Type == WebChat.Models.ChatType.Private)
        {
            var otherUser = chat.ChatUsers.FirstOrDefault(cu => cu.UserId != currentUserId)?.User;
            return (!string.IsNullOrWhiteSpace(otherUser?.FullName) ? otherUser.FullName : otherUser?.UserName) ?? chat.Name ?? "Trò chuyện";
        }
        return chat.Name ?? "Nhóm " + chat.Id;
    }

    string GetChatInitials(WebChat.Models.Chat chat, string currentUserId)
    {
        return GetInitials(GetChatName(chat, currentUserId));
    }

    string GetLastMessageText(WebChat.Models.Chat chat, string currentUserId)
    {
        var lastMessage = chat.Messages?.OrderByDescending(m => m.CreatedAt).FirstOrDefault();
        if (lastMessage == null) return "Chưa có tin nhắn nào";
        
        var senderName = lastMessage.SenderId == currentUserId 
            ? "Bạn" 
            : (!string.IsNullOrWhiteSpace(lastMessage.Sender?.FullName) ? lastMessage.Sender.FullName : lastMessage.Sender?.UserName) ?? "Ai đó";
        
        switch (lastMessage.Type)
        {
            case WebChat.Models.MessageType.Image:
                return $"{senderName}: [Hình ảnh]";
            case WebChat.Models.MessageType.Video:
                return $"{senderName}: [Video]";
            case WebChat.Models.MessageType.File:
                return $"{senderName}: [Tệp tin: {lastMessage.FileName}]";
            default:
                var content = lastMessage.Content ?? "";
                if (content.Length > 25) content = content.Substring(0, 22) + "...";
                return $"{senderName}: {content}";
        }
    }

    string GetLastMessageTime(WebChat.Models.Chat chat)
    {
        var lastMessage = chat.Messages?.OrderByDescending(m => m.CreatedAt).FirstOrDefault();
        if (lastMessage == null) return "";
        
        var localTime = lastMessage.CreatedAt.ToLocalTime();
        if (localTime.Date == DateTime.Today)
        {
            return localTime.ToString("HH:mm");
        }
        return localTime.ToString("dd/MM");
    }

    bool IsEmojiOnly(string? content)
    {
        if (string.IsNullOrWhiteSpace(content)) return false;
        foreach (var ch in content.Trim())
        {
            if (!char.IsWhiteSpace(ch) && char.GetUnicodeCategory(ch) != System.Globalization.UnicodeCategory.OtherSymbol)
            {
                return false;
            }
        }
        return true;
    }

    string BuildMediaUrl(string? fileUrl, int messageId)
    {
        if (string.IsNullOrWhiteSpace(fileUrl)) return "";
        return $"{fileUrl}?v={messageId}&sv={WebChat.Infrastructure.AppRuntime.InstanceToken}";
    }
}

<div class="chat-container">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show position-absolute top-0 start-50 translate-middle-x mt-3 z-3 shadow chat-alert" role="alert">
            <div class="d-flex align-items-center gap-2">
                <span class="material-symbols-outlined text-danger">warning</span>
                <span>@TempData["ErrorMessage"]</span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Sidebar -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <div class="sidebar-brand">
                <div class="position-relative">
                    <span class="material-symbols-outlined logo-icon">forum</span>
                    <span class="status-dot connecting position-absolute" id="connectionStatusDot" style="width: 8px; height: 8px; right: -2px; bottom: -2px; border: 1.5px solid var(--bg-surface-container-lowest);" title="Đang kết nối..."></span>
                </div>
                <div class="hidden-mobile">
                    <p class="sidebar-eyebrow">Tin nhắn</p>
                    <h5 class="m-0 font-weight-bold logo-text">WebChat</h5>
                </div>
            </div>
            <button class="btn btn-sm btn-new-chat rounded-circle d-flex align-items-center justify-content-center" id="btnNewChat" data-bs-toggle="modal" data-bs-target="#newChatModal" title="Tạo chat mới">
                <span class="material-symbols-outlined">add_comment</span>
            </button>
        </div>

        <div class="chat-list-header hidden-mobile">
            <div>
                <h6 class="chat-list-title">Cuộc trò chuyện</h6>
                <p class="chat-list-subtitle">Chọn một đoạn chat để tiếp tục.</p>
            </div>
            <span class="chat-list-count">@(Model.Chats?.Count ?? 0)</span>
        </div>

        <div class="chat-list">
            @if (Model.Chats != null)
            {
                var sortedChats = Model.Chats.OrderByDescending(c => c.Messages != null ? c.Messages.OrderByDescending(m => m.CreatedAt).FirstOrDefault()?.CreatedAt : DateTime.MinValue);
                foreach (var chat in sortedChats)
                {
                    var chatName = GetChatName(chat, Model.CurrentUser.Id);
                    var otherUser = chat.ChatUsers.FirstOrDefault(cu => cu.UserId != Model.CurrentUser.Id)?.User;
                    var currentUserChatUser = chat.ChatUsers.FirstOrDefault(cu => cu.UserId == Model.CurrentUser.Id);
                    var lastReadAt = currentUserChatUser?.LastReadAt ?? DateTime.MinValue;
                    var unreadCount = chat.Messages?.Count(m => m.SenderId != Model.CurrentUser.Id && m.CreatedAt > lastReadAt) ?? 0;
                    var hasUnread = unreadCount > 0;
                    
                    <a asp-page="/Chat" asp-route-chatId="@chat.Id" class="chat-list-item @(Model.ActiveChat?.Id == chat.Id ? "active" : "") @(hasUnread ? "unread" : "")" data-chat-id="@chat.Id">
                        <div class="avatar-circle position-relative">
                            @GetChatInitials(chat, Model.CurrentUser.Id)
                            @if (hasUnread)
                            {
                                <span class="status-dot online position-absolute sidebar-unread-dot" style="width: 10px; height: 10px; right: -2px; bottom: -2px; border: 2px solid var(--bg-surface-container-lowest);" id="unread-dot-@chat.Id"></span>
                            }
                        </div>
                        <div class="chat-list-item-content hidden-mobile">
                            <div class="d-flex justify-content-between align-items-center mb-0.5">
                                <h6 class="m-0 text-truncate chat-name-header"
                                    data-chat-name-for-chat-id="@chat.Id"
                                    data-private-chat-user-id="@(chat.Type == WebChat.Models.ChatType.Private ? otherUser?.Id : null)">
                                    @chatName
                                </h6>
                                <span class="chat-item-time text-muted" id="sidebar-time-@chat.Id">@GetLastMessageTime(chat)</span>
                            </div>
                            @{
                                var lastMessage = chat.Messages?.OrderByDescending(m => m.CreatedAt).FirstOrDefault();
                            }
                            <div class="chat-item-last-msg text-truncate"
                                 id="sidebar-msg-@chat.Id"
                                 data-last-message-sender-id="@lastMessage?.SenderId"
                                 data-last-message-type="@((int?)(lastMessage?.Type))"
                                 data-last-message-content="@lastMessage?.Content"
                                 data-last-message-file-name="@lastMessage?.FileName">
                                @GetLastMessageText(chat, Model.CurrentUser.Id)
                            </div>
                        </div>
                    </a>
                }
            }
            @if (Model.Chats == null || !Model.Chats.Any())
            {
                <div class="chat-list-empty hidden-mobile">
                    <span class="material-symbols-outlined">chat_bubble</span>
                    <p>Chưa có cuộc trò chuyện nào. Tạo chat mới để bắt đầu.</p>
                </div>
            }
        </div>

        <div class="sidebar-footer">
            <div class="sidebar-profile d-flex align-items-center gap-3 mb-2 w-100">
                <div class="avatar-circle-sm"
                     title="@(!string.IsNullOrWhiteSpace(Model.CurrentUser.FullName) ? Model.CurrentUser.FullName : Model.CurrentUser.UserName) (@Model.CurrentUser.Email)"
                     data-user-avatar-id="@Model.CurrentUser.Id">
                    @GetInitials(!string.IsNullOrWhiteSpace(Model.CurrentUser.FullName) ? Model.CurrentUser.FullName : Model.CurrentUser.UserName)
                </div>
                <div class="profile-info text-truncate hidden-mobile flex-grow-1">
                    <h6 class="m-0 font-weight-bold text-truncate"
                        style="font-size: 0.88rem; color: var(--on-surface);"
                        data-user-name-id="@Model.CurrentUser.Id">
                        @(!string.IsNullOrWhiteSpace(Model.CurrentUser.FullName) ? Model.CurrentUser.FullName : Model.CurrentUser.UserName)
                    </h6>
                    <small class="text-truncate d-block" style="font-size: 0.75rem; color: var(--on-surface); opacity: 0.75;">
                        @Model.CurrentUser.Email
                    </small>
                </div>
            </div>
            <button type="button" class="btn btn-sm btn-action w-100 d-flex align-items-center justify-content-center gap-2" data-bs-toggle="modal" data-bs-target="#settingsModal">
                <span class="material-symbols-outlined">settings</span>
                <span class="hidden-mobile">Cài đặt</span>
            </button>
            <form class="form-inline w-100 m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/Identity/Account/Login">
                <button type="submit" class="btn btn-sm btn-action-danger w-100 d-flex align-items-center justify-content-center gap-2">
                    <span class="material-symbols-outlined">logout</span>
                    <span class="hidden-mobile">Đăng xuất</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Main Chat Area -->
    <div class="chat-main-shell @(Model.ActiveChat?.Type == WebChat.Models.ChatType.Group ? "group-chat-open" : "")">
        <div class="chat-main">
        @if (Model.ActiveChat != null)
        {
            <div class="chat-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar-circle-sm @(Model.ActiveChat.Type == WebChat.Models.ChatType.Group ? "group-chat-avatar" : "")"
                         data-chat-header-avatar
                         data-private-chat-user-id="@(Model.ActiveChat.Type == WebChat.Models.ChatType.Private ? Model.ActiveChat.ChatUsers.FirstOrDefault(cu => cu.UserId != Model.CurrentUser.Id)?.User?.Id : null)">
                        @GetChatInitials(Model.ActiveChat, Model.CurrentUser.Id)
                    </div>
                    <div>
                        <h5 class="m-0 font-weight-bold text-truncate chat-header-title"
                            data-chat-header-name
                            data-private-chat-user-id="@(Model.ActiveChat.Type == WebChat.Models.ChatType.Private ? Model.ActiveChat.ChatUsers.FirstOrDefault(cu => cu.UserId != Model.CurrentUser.Id)?.User?.Id : null)">
                            @GetChatName(Model.ActiveChat, Model.CurrentUser.Id)
                        </h5>
                        <div class="d-flex align-items-center gap-1.5 mt-0.5">
                            @if (Model.ActiveChat.Type == WebChat.Models.ChatType.Private)
                            {
                                var otherUser = Model.ActiveChat.ChatUsers.FirstOrDefault(cu => cu.UserId != Model.CurrentUser.Id)?.User;
                                var isOnline = otherUser != null && WebChat.Hubs.ChatHub.IsUserOnline(otherUser.Id);
                                <span class="status-dot @(isOnline ? "online" : "offline")" id="partnerStatusDot" style="width: 7px; height: 7px;"></span>
                                <small class="status-text font-weight-bold" id="partnerStatusText" style="font-size: 0.75rem;">@(isOnline ? "Online" : "Offline")</small>
                                @if (otherUser != null)
                                {
                                    <input type="hidden" id="partnerUserId" value="@otherUser.Id" />
                                }
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-muted" style="font-size: 0.9rem;">group</span>
                                <small class="status-text font-weight-bold" style="font-size: 0.75rem;">@Model.ActiveChat.ChatUsers.Count thành viên</small>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="chat-messages" id="messagesList">
                @if (Model.ActiveChat.Messages != null)
                {
                    foreach (var message in Model.ActiveChat.Messages.OrderBy(m => m.CreatedAt))
                    {
                        var isCurrentUser = message.SenderId == Model.CurrentUser.Id;
                        <div class="message-wrapper @(isCurrentUser ? "justify-content-end" : "")">
                            @if (!isCurrentUser)
                            {
                                var senderDisplayName = !string.IsNullOrWhiteSpace(message.Sender.FullName) ? message.Sender.FullName : message.Sender.UserName;
                                <div class="avatar-circle-sm mb-1 align-self-end"
                                     title="@senderDisplayName"
                                     data-user-avatar-id="@message.SenderId">
                                    @GetInitials(senderDisplayName)
                                </div>
                            }
                            @{
                                var messageBoxClasses = $"{(isCurrentUser ? "right-msg" : "left-msg")} {(message.Type == WebChat.Models.MessageType.Image || message.Type == WebChat.Models.MessageType.Video ? "media-message" : "")} {(message.Type == WebChat.Models.MessageType.Icon || IsEmojiOnly(message.Content) ? "emoji-message" : "")}";
                            }
                            <div class="message-box @messageBoxClasses">
                                @if (!isCurrentUser)
                                {
                                    var senderDisplayName = !string.IsNullOrWhiteSpace(message.Sender.FullName) ? message.Sender.FullName : message.Sender.UserName;
                                    <div class="sender-name" data-user-name-id="@message.SenderId">@senderDisplayName</div>
                                }
                                
                                <div class="message-content">
                                    @if (message.Type == WebChat.Models.MessageType.Text || message.Type == WebChat.Models.MessageType.Icon)
                                    {
                                        <span>@message.Content</span>
                                    }
                                    else if (message.Type == WebChat.Models.MessageType.Image)
                                    {
                                        var imageUrl = BuildMediaUrl(message.FileUrl, message.Id);
                                        <img src="@imageUrl" class="chat-img img-fluid" alt="image" onclick="zoomImage(this.src)" />
                                        @if (!string.IsNullOrWhiteSpace(message.Content))
                                        {
                                            <div class="media-caption">@message.Content</div>
                                        }
                                    }
                                    else if (message.Type == WebChat.Models.MessageType.Video)
                                    {
                                        var videoUrl = BuildMediaUrl(message.FileUrl, message.Id);
                                        <div class="chat-video-shell" data-video-shell>
                                            <button type="button"
                                                    class="chat-video-placeholder"
                                                    data-video-src="@videoUrl"
                                                    onclick="loadInlineVideo(this)">
                                                <span class="material-symbols-outlined">play_circle</span>
                                                <span>Xem video</span>
                                            </button>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(message.Content))
                                        {
                                            <div class="media-caption">@message.Content</div>
                                        }
                                    }
                                    else if (message.Type == WebChat.Models.MessageType.File)
                                    {
                                        <div class="file-attachment-card" onclick="window.open('@message.FileUrl', '_blank')">
                                            <div class="file-icon-box @(message.FileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true ? "pdf" : "generic")">
                                                <span class="material-symbols-outlined">@(message.FileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true ? "picture_as_pdf" : "description")</span>
                                            </div>
                                            <div class="file-info">
                                                <p class="file-name" title="@message.FileName">@message.FileName</p>
                                                <p class="file-size">@(string.IsNullOrEmpty(message.Content) ? "Tài liệu" : message.Content)</p>
                                            </div>
                                            <a href="@message.FileUrl" download="@message.FileName" class="file-download-btn" onclick="event.stopPropagation();" target="_blank">
                                                <span class="material-symbols-outlined">download</span>
                                            </a>
                                        </div>
                                    }
                                </div>
                                <div class="message-time @(isCurrentUser ? "right" : "left")">@message.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="chat-input-area">
                <div id="uploadProgressContainer" class="d-none mb-3">
                    <div class="progress upload-progress">
                        <div id="uploadProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"></div>
                    </div>
                </div>
                <div id="mediaPreviewContainer" class="media-preview-container d-none"></div>

                <div class="input-wrapper">
                    <button class="input-action-btn" type="button" id="btnAttachFile" title="Đính kèm tệp">
                        <span class="material-symbols-outlined">attach_file</span>
                    </button>
                    <button class="input-action-btn" type="button" id="btnAttachImage" title="Đính kèm ảnh">
                        <span class="material-symbols-outlined">image</span>
                    </button>
                    <button class="input-action-btn" type="button" id="btnAttachVideo" title="Đính kèm video">
                        <span class="material-symbols-outlined">videocam</span>
                    </button>
                    <button class="input-action-btn" type="button" id="btnEmoji" title="Biểu cảm">
                        <span class="material-symbols-outlined">mood</span>
                    </button>
                    
                    <div id="emojiPicker" class="emoji-picker d-none">
                        <!-- Emojis injected by JS -->
                    </div>

                    <input type="text" id="messageInput" placeholder="Nhập tin nhắn cho cuộc trò chuyện này..." autocomplete="off" />
                    <button class="send-btn" type="button" id="btnSend" title="Gửi">
                        <span class="material-symbols-outlined">send</span>
                    </button>
                </div>

                <div class="composer-meta">
                    <span>Enter để gửi</span>
                    <span>Ảnh/video có thể thêm chú thích trước khi gửi</span>
                </div>
                
                <!-- Hidden inputs for file/image/video -->
                <input type="file" id="fileInput" class="d-none" />
                <input type="file" id="imageInput" accept="image/*" class="d-none" />
                <input type="file" id="videoInput" accept="video/*" class="d-none" />
            </div>
            
            <input type="hidden" id="currentChatId" value="@Model.ActiveChat.Id" />
        }
        else
        {
            <div class="empty-chat-state">
                <div class="empty-chat-icon-container">
                    <span class="material-symbols-outlined bubble-icon">forum</span>
                </div>
                <h4 class="empty-chat-title">Chọn một cuộc trò chuyện</h4>
                <p class="empty-chat-subtitle">Mọi tin nhắn, tệp và hình ảnh sẽ hiển thị ở đây. Bạn cũng có thể tạo một đoạn chat mới bằng email.</p>
                <button class="btn-new-chat-hero" data-bs-toggle="modal" data-bs-target="#newChatModal">
                    <span class="material-symbols-outlined">add_comment</span>
                    <span>Tạo cuộc trò chuyện mới</span>
                </button>
            </div>
        }
        </div>

        @if (Model.ActiveChat?.Type == WebChat.Models.ChatType.Group)
        {
            <aside class="chat-members-panel">
                <div class="chat-members-header">
                    <p class="chat-members-eyebrow">Thành viên</p>
                    <h6 class="chat-members-title">@Model.ActiveChat.ChatUsers.Count người tham gia</h6>
                </div>
                <div class="chat-members-list">
                    @foreach (var member in Model.ActiveChat.ChatUsers
                       .OrderByDescending(cu => cu.UserId == Model.CurrentUser.Id)
                       .ThenBy(cu => !string.IsNullOrWhiteSpace(cu.User.FullName) ? cu.User.FullName : cu.User.UserName))
                    {
                        var displayName = !string.IsNullOrWhiteSpace(member.User.FullName) ? member.User.FullName : member.User.UserName;
                        var isCurrentUser = member.UserId == Model.CurrentUser.Id;
                        var isOnline = WebChat.Hubs.ChatHub.IsUserOnline(member.UserId);
                        <div class="chat-member-card">
                            <div class="chat-member-avatar" title="@displayName">
                                @GetInitials(displayName)
                            </div>
                            <div class="chat-member-info">
                                <div class="chat-member-name-row">
                                    <span class="chat-member-name" data-user-name-id="@member.UserId">@displayName</span>
                                    @if (member.Role == WebChat.Models.UserRole.Admin)
                                    {
                                        <span class="chat-member-role">Admin</span>
                                    }
                                </div>
                                <div class="chat-member-meta">
                                    <span class="status-dot @(isOnline ? "online" : "offline")"></span>
                                    <span>@(isCurrentUser ? "Bạn" : (isOnline ? "Đang hoạt động" : "Ngoại tuyến"))</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </aside>
        }
    </div>
</div>
<input type="hidden" id="currentUserId" value="@Model.CurrentUser.Id" />
<input type="hidden" id="serverInstanceToken" value="@WebChat.Infrastructure.AppRuntime.InstanceToken" />

<!-- Image Lightbox Modal -->
<div id="imageLightbox" class="lightbox-modal" onclick="closeLightbox()">
    <span class="lightbox-close">&times;</span>
    <div class="lightbox-content-wrapper" onclick="event.stopPropagation();">
        <img class="lightbox-content" id="lightboxImage" alt="Hình ảnh xem trước">
    </div>
</div>


<!-- New Chat Modal -->
<div class="modal fade" id="newChatModal" tabindex="-1" aria-labelledby="newChatModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form method="post" asp-page-handler="CreateChat">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title font-weight-bold" id="newChatModalLabel">Tạo Chat Mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label for="chatMode" class="form-label font-weight-bold text-muted" style="font-size: 0.85rem;">Loại cuộc trò chuyện:</label>
                        <select class="form-select" id="chatMode" name="ChatMode" style="border-radius: 12px; padding: 12px 16px;">
                            <option value="private">Chat riêng</option>
                            <option value="group">Tạo nhóm</option>
                        </select>
                    </div>

                    <div id="privateChatFields">
                        <div class="mb-3">
                            <label for="targetEmail" class="form-label font-weight-bold text-muted" style="font-size: 0.85rem;">Email người cần chat:</label>
                            <input type="email" class="form-control" id="targetEmail" name="TargetEmail" placeholder="name@example.com" style="border-radius: 12px; padding: 12px 16px;">
                        </div>
                    </div>

                    <div id="groupChatFields" class="d-none">
                        <div class="mb-3">
                            <label for="groupName" class="form-label font-weight-bold text-muted" style="font-size: 0.85rem;">Tên nhóm:</label>
                            <input type="text" class="form-control" id="groupName" name="GroupName" placeholder="Ví dụ: PRN222 Team" style="border-radius: 12px; padding: 12px 16px;">
                        </div>
                        <div class="mb-0">
                            <label for="groupMemberEmails" class="form-label font-weight-bold text-muted" style="font-size: 0.85rem;">Email thành viên:</label>
                            <textarea class="form-control" id="groupMemberEmails" name="GroupMemberEmails" rows="4" placeholder="name1@example.com, name2@example.com" style="border-radius: 12px; padding: 12px 16px;"></textarea>
                            <div class="form-text">Phân tách bằng dấu phẩy, chấm phẩy hoặc xuống dòng.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light-custom" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary-custom">Tạo / Mở Chat</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Settings Modal -->
<div class="modal fade" id="settingsModal" tabindex="-1" aria-labelledby="settingsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="height: 80vh; overflow: hidden; background: var(--bg-surface-container); border-radius: 20px;">
            <div class="modal-header border-bottom-0 pb-0" style="padding: 1.5rem 1.5rem 0.5rem 1.5rem;">
                <h5 class="modal-title font-weight-bold" id="settingsModalLabel">Cài đặt tài khoản</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0" style="height: calc(100% - 60px);">
                <iframe src="about:blank" style="width: 100%; height: 100%; border: none; border-radius: 0 0 20px 20px; background: transparent;" id="settingsIframe" allowtransparency="true"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
